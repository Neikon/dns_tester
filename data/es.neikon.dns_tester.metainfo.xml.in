<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>es.neikon.dns_tester</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>

  <name>DNS_Tester</name>
  <summary>Keep the summary shorter, between 10 and 35 characters</summary>
  <description>
    <p>No description</p>
  </description>

  <developer id="tld.vendor">
    <name>Developer name</name>
  </developer>

  <!-- Required: Should be a link to the upstream homepage for the component -->
  <url type="homepage">https://example.org/</url>
  <!-- Recommended: It is highly recommended for open-source projects to display the source code repository -->
  <url type="vcs-browser">https://example.org/repository</url>
  <!-- Should point to the software's bug tracking system, for users to report new bugs -->
  <url type="bugtracker">https://example.org/issues</url>
  <!-- Should link a FAQ page for this software, to answer some of the most-asked questions in detail -->
  <!-- URLs of this type should point to a webpage where users can submit or modify translations of the upstream project -->
  <url type="translate">https://example.org/translate</url>
  <url type="faq">https://example.org/faq</url>
  <!-- Should provide a web link to an online user's reference, a software manual or help page -->
  <url type="help">https://example.org/help</url>
  <!-- URLs of this type should point to a webpage showing information on how to donate to the described software project -->
  <url type="donation">https://example.org/donate</url>
  <!-- This could for example be an HTTPS URL to an online form or a page describing how to contact the developer -->
  <url type="contact">https://example.org/contact</url>
  <!-- URLs of this type should point to a webpage showing information on how to contribute to the described software project -->
  <url type="contribute">https://example.org/contribute</url>

  <translation type="gettext">dns_tester</translation>
  <!-- All graphical applications having a desktop file must have this tag in the MetaInfo.
     If this is present, appstreamcli compose will pull icons, keywords and categories from the desktop file. -->
  <launchable type="desktop-id">es.neikon.dns_tester.desktop</launchable>
  <!-- Use the OARS website (https://hughsie.github.io/oars/generate.html) to generate these and make sure to use oars-1.1 -->
  <content_rating type="oars-1.1" />

  <!-- Applications should set a brand color in both light and dark variants like so -->
  <branding>
    <color type="primary" scheme_preference="light">#ff00ff</color>
    <color type="primary" scheme_preference="dark">#993d3d</color>
  </branding>

  <screenshots>
    <screenshot type="default">
      <image>https://example.org/example1.png</image>
      <caption>A caption</caption>
    </screenshot>
    <screenshot>
      <image>https://example.org/example2.png</image>
      <caption>A caption</caption>
    </screenshot>
  </screenshots>

  <releases>
    <release version="26.03.30.2030" date="2026-03-30">
      <url type="details">https://github.com/Neikon/dns_tester/releases/tag/26.03.30.2030</url>
      <description translate="no">
        <p>This release modernizes DNS benchmarking and improves resolver management.</p>
        <ul>
          <li>Add fair benchmarking for Do53, DoT, and DoH with warm-up, connection reuse, cache control, and structured latency metrics.</li>
          <li>Add a ranked Check All results dialog and move benchmark settings into a dedicated preferences dialog.</li>
          <li>Persist custom DNS entries and hidden bundled entries across restarts, including reset defaults support and structured origin metadata.</li>
          <li>Fix benchmark JSON copy so exporting results works correctly on GTK4 and Wayland sessions.</li>
          <li>Ignore the local Codex marker file so repository status stays focused on project changes.</li>
          <li>Clarify the Git workflow so finished local commits are pushed automatically after integration work.</li>
          <li>Rework DNS browsing into a libadwaita 1.9 provider sidebar so each provider reveals its profiles and each profile expands into transport variants using the new AdwSidebar navigation.</li>
          <li>Separate shipped providers from user-defined ones in the sidebar with dedicated Bundled and Custom sections.</li>
          <li>Open the Check All results dialog immediately and refresh it live with progress while benchmarks are still running.</li>
          <li>Move the Check All action into the header bar so the provider sidebar stays focused on navigation.</li>
          <li>Add a tooltip to the Check All button so bulk benchmarking is clearer before running it.</li>
          <li>Simplify the main window layout by removing an unnecessary root container around the split view.</li>
          <li>Reimplement the provider browser around AdwNavigationSplitView with responsive sidebar-page behavior based on the libadwaita documentation.</li>
          <li>Move the Check All action next to the provider controls as a compact icon button in the sidebar header.</li>
          <li>Use a clearer play-style icon for the Check All action so it better communicates running every benchmark.</li>
          <li>Remove region flags from provider names in the sidebar to keep the navigation list cleaner.</li>
          <li>Keep provider titles plain throughout the UI and leave the region flags only in the dedicated origin line.</li>
          <li>Update the README screenshot to match the current provider-browser interface and remove the outdated image.</li>
          <li>Add provider-specific sidebar icons for the bundled DNS services while keeping a generic network icon for custom providers.</li>
          <li>Replace the placeholder ControlD provider icon with the favicon published by the ControlD website.</li>
          <li>Clean up the bundled sidebar icon assets by removing an unused provider icon subdirectory.</li>
          <li>Raise the Flatpak runtime to GNOME 50 so the new sidebar widgets are available in the shipped app.</li>
          <li>Integrate the new sidebar layout more cleanly and move the Check All action into a fixed footer at the bottom of the provider list.</li>
        </ul>
      </description>
    </release>
  </releases>

</component>
